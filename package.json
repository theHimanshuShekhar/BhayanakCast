{
  "name": "bhayanak_cast",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "concurrently \"pnpm:dev:web\" \"pnpm:dev:ws\"",
    "dev:web": "vite dev --port 3000",
    "dev:ws": "tsx watch websocket-server.ts",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview",
    "test": "DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/bhayanak_cast_test\" vitest run",
    "test:watch": "DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/bhayanak_cast_test\" vitest",
    "test:coverage": "DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/bhayanak_cast_test\" vitest run --coverage",
    "test:ui": "DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/bhayanak_cast_test\" vitest --ui",
    "test:setup": "docker exec bhayanak-postgres psql -U postgres -c 'CREATE DATABASE IF NOT EXISTS bhayanak_cast_test;'",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@daveyplate/better-auth-tanstack": "^1.3.6",
    "@daveyplate/better-auth-ui": "^3.3.15",
    "@posthog/react": "^1.7.0",
    "@t3-oss/env-core": "^0.13.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/pacer": "^0.19.0",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.4.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.0",
    "lucide-react": "^0.561.0",
    "nanoid": "^5.1.6",
    "nitro": "npm:nitro-nightly@latest",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "posthog-js": "^1.335.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^8.2.2",
    "dotenv": "^16.0.0",
    "jsdom": "^27.0.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "zod": "^4.3.5"
  }
}
