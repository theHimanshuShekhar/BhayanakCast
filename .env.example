# Database URL for PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
VITE_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-key-here

# WebSocket Server Configuration
# Port is automatically parsed from VITE_WS_URL
CLIENT_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3001

# PostHog configuration
VITE_POSTHOG_KEY=your-posthog-key
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Discord OAuth (used in both dev and production)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
# Set redirect URL in Discord Developer Portal:
# - Development: http://localhost:3000/api/auth/callback/discord
# - Production: https://yourdomain.com/api/auth/callback/discord

# Test Authentication (auto-enabled in test environment)
# Email/password auth is automatically enabled when NODE_ENV=test
# This allows E2E tests to create test users programmatically
# DO NOT enable in production
